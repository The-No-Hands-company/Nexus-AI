#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

HOOK_BIN="${DETECT_SECRETS_HOOK:-}"
if [[ -z "${HOOK_BIN}" ]]; then
  if command -v detect-secrets-hook >/dev/null 2>&1; then
    HOOK_BIN="$(command -v detect-secrets-hook)"
  elif [[ -x "${repo_root}/.venv/bin/detect-secrets-hook" ]]; then
    HOOK_BIN="${repo_root}/.venv/bin/detect-secrets-hook"
  elif [[ -x "${HOME}/.local/bin/detect-secrets-hook" ]]; then
    HOOK_BIN="${HOME}/.local/bin/detect-secrets-hook"
  else
    HOOK_BIN=""
  fi
fi

mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=ACM)
if [[ "${#staged_files[@]}" -eq 0 ]]; then
  exit 0
fi

if printf '%s\n' "${staged_files[@]}" | rg -n '(^|/)\.env($|\.)|vite\.config\.ts\.timestamp-.*\.mjs$' >/dev/null; then
  echo "Blocked: .env or vite timestamp temp file detected in staged changes."
  exit 1
fi

if [[ -z "${HOOK_BIN}" || ! -x "${HOOK_BIN}" ]]; then
  echo "Missing detect-secrets hook binary."
  echo "Set DETECT_SECRETS_HOOK or install detect-secrets-hook in PATH/.venv/.local."
  exit 1
fi

"${HOOK_BIN}" "${staged_files[@]}"
