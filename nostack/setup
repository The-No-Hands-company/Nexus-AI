#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
NOSTACK_HOME="${HOME}/.nexus/nostack"
SKILLS_DEST="${NOSTACK_HOME}/skills"
SKILLS_SRC="${SCRIPT_DIR}/skills"
CONFIG_FILE=".nostackrc"
PROJECT_MODE=false
HELP=false

usage() {
    cat <<EOF
nostack setup — install the virtual engineering team for Nexus AI

Usage:
  nostack/setup              Register nostack agents globally
  nostack/setup --project    Register agents and create .nostackrc in project root
  nostack/setup --help       Show this help

Description:
  Checks dependencies, copies skill files, registers agent specializations,
  and optionally creates a project-level config file.

  This script is safe to run multiple times — it is fully idempotent.
EOF
}

for arg in "$@"; do
    case "$arg" in
        --help|-h) HELP=true ;;
        --project|-p) PROJECT_MODE=true ;;
        *) echo "Unknown argument: $arg"; echo "Run with --help for usage."; exit 2 ;;
    esac
done

if $HELP; then
    usage
    exit 0
fi

echo "==> nostack setup"
echo ""

# ── Check dependencies ────────────────────────────────────────────────────────

echo "── Checking dependencies"

# Bash
if ! command -v bash &>/dev/null; then
    echo "ERROR: bash is required but not found."
    exit 1
fi
echo "  [OK] bash $(bash --version | head -1 | grep -oP '\d+\.\d+\.\d+')"

# Python 3.11+
if ! command -v python3 &>/dev/null; then
    echo "ERROR: python3 is required but not found."
    exit 1
fi

PY_VER=$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')
PY_MAJOR=$(echo "$PY_VER" | cut -d. -f1)
PY_MINOR=$(echo "$PY_VER" | cut -d. -f2)

if [ "$PY_MAJOR" -lt 3 ] || { [ "$PY_MAJOR" -eq 3 ] && [ "$PY_MINOR" -lt 11 ]; }; then
    echo "ERROR: Python 3.11+ required. Found: $PY_VER"
    exit 1
fi
echo "  [OK] python $PY_VER"

# ── Create nostack home directory ─────────────────────────────────────────────

echo ""
echo "── Setting up ${NOSTACK_HOME}"
mkdir -p "$NOSTACK_HOME"
mkdir -p "$SKILLS_DEST"

# ── Copy skill files ──────────────────────────────────────────────────────────

echo ""
echo "── Installing skills"

if [ ! -d "$SKILLS_SRC" ]; then
    echo "ERROR: skills directory not found at ${SKILLS_SRC}"
    exit 1
fi

COUNT=0
for skill_file in "$SKILLS_SRC"/*.md; do
    if [ -f "$skill_file" ]; then
        skill_name="$(basename "$skill_file")"
        cp "$skill_file" "${SKILLS_DEST}/${skill_name}"
        COUNT=$((COUNT + 1))
    fi
done
echo "  Installed ${COUNT} skill(s) to ${SKILLS_DEST}"

# ── Register nostack agents ───────────────────────────────────────────────────

echo ""
echo "── Registering nostack agents"

PYTHONPATH="${PROJECT_ROOT}/src${PYTHONPATH:+:$PYTHONPATH}" python3 -c "
from nostack.registry import register_all
register_all()
" 2>&1 || {
    echo ""
    echo "  [NOTE] Agent registration skipped — nostack.registry not importable."
    echo "         Skills are installed. Agents can be registered later with:"
    echo "           python -c 'from nostack.registry import register_all; register_all()'"
}

# ── Create .nostackrc if --project ────────────────────────────────────────────

if $PROJECT_MODE; then
    echo ""
    echo "── Creating project config"

    RC_PATH="${PROJECT_ROOT}/${CONFIG_FILE}"
    if [ ! -f "$RC_PATH" ]; then
        cat > "$RC_PATH" <<'RCEOF'
# nostack — Virtual Engineering Team Configuration
# Generated by nostack/setup

# Enable nostack agents in this project
nostack.enabled = true

# Skill directories
nostack.skills_dir = ~/.nexus/nostack/skills
nostack.project_skills_dir = ./nostack/skills

# Agent provider preferences
nostack.default_provider = groq
nostack.default_model =

# Chain timeout (seconds)
nostack.chain_timeout_s = 600
RCEOF
        echo "  Created ${RC_PATH}"
    else
        echo "  ${RC_PATH} already exists — skipped"
    fi
fi

# ── Summary ───────────────────────────────────────────────────────────────────

echo ""
echo "==> Setup complete!"
echo ""
echo "  Skills installed: ${COUNT}"
echo "  Location:         ${SKILLS_DEST}"
echo ""

if $PROJECT_MODE; then
    echo "  Project config:   ${RC_PATH}"
    echo ""
fi

echo "  Quick start:"
echo "    # Chat with Nexus AI and invoke a skill:"
echo "    #   \\"Run /office-hours — I want to build a daily briefing app\\""
echo ""
echo "    # Or use the CLI tool directly:"
echo "    #   nostack/bin/nostack-run office-hours"
echo ""
echo "  The sprint:"
echo "    /office-hours → /plan-ceo-review → /plan-eng-review → /review → /qa → /ship"
echo ""

SKILL_LIST=$(ls "$SKILLS_DEST"/*.md 2>/dev/null | while read -r f; do
    name="$(basename "$f" .md)"
    role="$(head -5 "$f" | grep -i '^## Role:' | sed 's/^## Role:[[:space:]]*//' || echo '')"
    printf "    %-28s %s\n" "/$name" "$role"
done)

if [ -n "$SKILL_LIST" ]; then
    echo "  Installed specializations:"
    echo "$SKILL_LIST"
fi

echo ""
echo "  Run 'nostack/setup --help' for more options."
