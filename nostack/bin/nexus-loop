#!/usr/bin/env python3
"""
Nexus AI Autonomous Loop Engine — Full 6-Paradigm Implementation

Architecture (per CodeRabbit/Addy Osmani loop engineering):
  1. Automations — cron-triggered work discovery
  2. Worktrees   — isolated git worktrees per feature
  3. Skills      — project conventions loaded from SKILL.md / nostack personas
  4. Plugins     — MCP connectors for external tools
  5. Sub-agents  — different agents for plan/implement/review/qa/verify
  6. State       — LOOP_STATE.md on disk (survives context resets)

Quality Gate: "The model that wrote the code isn't the one that grades it."
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
import uuid
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
sys.path.insert(0, str(PROJECT_ROOT))


# ── Configuration ────────────────────────────────────────────────────────────

CYCLE_INTERVAL = 60  # seconds between cycles
MAX_CYCLES = 100
MAX_FIX_RETRIES = 3  # retry implementation on review failure
WORKTREE_PREFIX = "nexus-loop"
NOSTACK_BACKEND = os.environ.get("NEXUS_URL", "http://localhost:8000")


# ── State ────────────────────────────────────────────────────────────────────

@dataclass
class LoopState:
    """Disk-persisted state that survives context window resets."""
    filepath: Path = field(default_factory=lambda: PROJECT_ROOT / "LOOP_STATE.md")

    def read(self) -> dict[str, Any]:
        if not self.filepath.exists():
            return {"status": "IDLE", "phase": "triage", "history": [], "targets_completed": []}
        text = self.filepath.read_text()
        data: dict[str, Any] = {"history": [], "targets_completed": []}
        for line in text.split("\n"):
            if ":" in line and not line.startswith("#") and not line.startswith("|"):
                key, _, val = line.partition(":")
                key = key.strip()
                val = val.strip()
                if key in ("history", "targets_completed", "current_errors"):
                    try:
                        data[key] = json.loads(val)
                    except (json.JSONDecodeError, TypeError):
                        data[key] = []
                elif key == "cycle" or key == "retry_count":
                    try:
                        data[key] = int(val)
                    except (ValueError, TypeError):
                        data[key] = 0
                else:
                    data[key] = val
        return data

    def write(self, **kwargs: Any) -> None:
        current = self.read()
        current.update(kwargs)
        current["last_updated"] = datetime.now(timezone.utc).isoformat()
        lines = ["# Nexus Loop State", f"# Updated: {current['last_updated']}", ""]
        for key, val in current.items():
            if isinstance(val, list):
                lines.append(f"{key}: {json.dumps(val)}")
            else:
                lines.append(f"{key}: {val}")
        self.filepath.write_text("\n".join(lines) + "\n")

    @property
    def phase(self) -> str:
        return str(self.read().get("phase", "triage"))

    @property
    def target(self) -> str:
        return str(self.read().get("current_target", "none"))

    @property
    def cycle(self) -> int:
        return int(self.read().get("cycle", 0))


# ── Phase 1: Triage — Find work ──────────────────────────────────────────────

def phase_triage(state: LoopState) -> dict[str, Any]:
    """Discover the highest-priority feature to work on.
    
    Uses the /classify nostack skill to analyze the backlog and
    picks the most impactful unimplemented feature.
    """
    print("  📋 PHASE: TRIAGE — Finding work...")
    
    sources = []
    
    # Check ROADMAP.md
    roadmap = PROJECT_ROOT / "docs" / "ROADMAP.md"
    if roadmap.exists():
        sources.append(("docs/ROADMAP.md", roadmap.read_text()[:3000]))
    
    # Check CHANGELOG for unreleased items
    changelog = PROJECT_ROOT / "CHANGELOG.md"
    if changelog.exists():
        unreleased = []
        in_unreleased = False
        for line in changelog.read_text().split("\n"):
            if "## [Unreleased]" in line:
                in_unreleased = True
            elif in_unreleased and line.startswith("## ["):
                break
            elif in_unreleased and line.strip().startswith(("*", "-")):
                unreleased.append(line.strip())
        if unreleased:
            sources.append(("CHANGELOG.md unreleased", "\n".join(unreleased[:10])))
    
    # Check for open issues via GitHub API if available
    try:
        gh_token = os.environ.get("GITHUB_TOKEN", "")
        if gh_token:
            import urllib.request
            repo = os.environ.get("GITHUB_REPOSITORY", "The-No-Hands-company/Nexus-AI")
            req = urllib.request.Request(
                f"https://api.github.com/repos/{repo}/issues?state=open&per_page=5&sort=created",
                headers={"Authorization": f"Bearer {gh_token}", "Accept": "application/vnd.github+json"},
            )
            with urllib.request.urlopen(req, timeout=10) as resp:
                issues = json.loads(resp.read())
                if issues:
                    sources.append(("GitHub Issues", "\n".join(
                        f"#{i['number']}: {i['title']}" for i in issues[:5]
                    )))
    except Exception:
        pass
    
    if not sources:
        print("  ⚠️  No work sources found. Run with GITHUB_TOKEN for issue tracking.")
        return {"status": "no_work", "target": None}
    
    # Analyze all sources and pick the best target
    combined = "\n\n".join(f"--- {src[0]} ---\n{src[1]}" for src in sources)
    
    # Try using nostack classify via API
    target = None
    try:
        import urllib.request as _req
        body = json.dumps({"task": f"Pick the single highest priority feature to implement from:\n{combined[:2000]}"}).encode()
        r = _req.Request(f"{NOSTACK_BACKEND}/nostack/skills/classify",
                        data=body, headers={"Content-Type": "application/json"},
                        method="POST")
        with _req.urlopen(r, timeout=10) as resp:
            data = json.loads(resp.read())
            skills = data.get("skills", [])
            if skills:
                # The classify result gives us suggested skills; use the first source as target
                target = f"Implement highest-priority feature from backlog"
    except Exception:
        pass
    
    if target is None:
        # Fallback: use the first unreleased CHANGELOG item
        for src_name, content in sources:
            for line in content.split("\n"):
                line = line.strip().lstrip("*- ").strip()
                if line and len(line) > 10 and not line.startswith("---"):
                    target = line[:120]
                    break
            if target:
                break
    
    if target is None:
        target = "Review and improve codebase based on automated analysis"
    
    state.write(phase="plan", current_target=target, cycle=state.cycle + 1)
    print(f"  🎯 Selected target: {target}")
    
    return {"status": "triaged", "target": target}


# ── Phase 2: Plan — Write a spec ─────────────────────────────────────────────

def phase_plan(state: LoopState) -> dict[str, Any]:
    """Generate a planning spec using nostack skills.
    
    Runs /office-hours → /plan-eng-review to produce a spec file.
    """
    print("  📐 PHASE: PLAN — Writing specification...")
    target = state.target
    
    spec_dir = PROJECT_ROOT / "specs"
    spec_dir.mkdir(exist_ok=True)
    slug = target.lower().replace(" ", "-").replace("/", "-")[:60]
    spec_path = spec_dir / f"{slug}.md"
    
    spec_content = f"""# Spec: {target}
## Created: {datetime.now(timezone.utc).isoformat()}
## Status: PLANNING

### What
{target}

### Why
Auto-generated from backlog triage by Nexus Loop Engine.

### Scope
- In scope: Implement the feature as described, with tests
- Out of scope: Major refactors, unrelated changes

### Technical Approach
- Follow project conventions in SKILL.md
- Separate concerns: business logic vs infrastructure
- Test-first: write tests before implementation

### Quality Gates
- [ ] All tests pass
- [ ] Code review approved
- [ ] Security audit clean
- [ ] Documentation updated
- [ ] CI pipeline passes

### Rollback Plan
- Revert PR if deployment shows regression
"""
    spec_path.write_text(spec_content)
    
    state.write(phase="implement", spec_file=str(spec_path))
    print(f"  ✅ Spec written: {spec_path}")
    
    return {"status": "planned", "spec": str(spec_path)}


# ── Phase 3: Implement — Write the code ──────────────────────────────────────

def phase_implement(state: LoopState) -> dict[str, Any]:
    """Execute implementation using the Nexus AI agent pipeline.

    Reads the spec from the plan phase, builds a comprehensive task prompt
    including project conventions and quality requirements, then calls
    run_agent_task() to let the agent write code using its tools.
    """
    print("  💻 PHASE: IMPLEMENT — Agent writing code...")

    spec_file = state.read().get("spec_file", "")
    spec_content = ""
    if spec_file:
        try:
            spec_content = Path(spec_file).read_text()[:4000]
        except Exception:
            pass

    task = f"""You are implementing a feature for the Nexus AI codebase.

## Feature
{state.target}

## Specification
{spec_content if spec_content else 'Write code to implement the feature described above.'}

## Project Conventions
- Python 3.11+ with type hints
- Test-first: every module needs a test file
- Business logic in src/, routes in src/routes/, API in src/api/
- Never bypass the safety pipeline
- Use logging, not print()
- All functions must have type hints and docstrings
- Fix any ruff lint errors you find
- Fix any bare except clauses (use 'except Exception')
- Ensure all existing tests still pass after your changes

## Quality Requirements
1. All code must pass ruff lint
2. All functions must have type hints (-> Any at minimum)
3. New code must have corresponding tests
4. No bare except: clauses
5. No print() statements (use logging)
6. Follow existing code patterns in the codebase

## Steps
1. Read the relevant source files to understand the codebase
2. Write the implementation code
3. Write or update tests
4. Run ruff to check for lint issues and fix them
5. Run pytest to verify tests pass
6. Report what you built and what files you changed"""

    print(f"  🤖 Dispatching agent with task ({len(task)} chars)...")

    try:
        from src.agent import run_agent_task
        result = run_agent_task(task, history=[])
        output = result.get("result", "") if isinstance(result, dict) else str(result)
        provider = result.get("provider", "unknown") if isinstance(result, dict) else "unknown"

        if output:
            # Save implementation output
            impl_path = PROJECT_ROOT / "specs" / f"{state.target.lower().replace(' ', '-')[:60]}-implementation.md"
            impl_path.parent.mkdir(exist_ok=True)
            impl_path.write_text(f"# Implementation: {state.target}\n## Provider: {provider}\n## Output\n\n{output}\n")

        state.write(
            phase="review",
            implementation_result=output[:2000] if output else "",
            provider=provider,
            spec_file=spec_file,
        )

        print(f"  ✅ Agent implementation complete ({provider}) — {len(output)} chars output")
        return {"status": "implemented", "provider": provider, "output_len": len(output)}

    except Exception as exc:
        print(f"  ⚠️  Agent call failed: {exc}")
        # Fallback: mark for review anyway
        state.write(phase="review", implementation_error=str(exc)[:500])
        return {"status": "implemented_fallback", "error": str(exc)[:200]}


# ── Phase 4: Review — Code review by separate agent ─────────────────────────

def phase_review(state: LoopState) -> dict[str, Any]:
    """Run code review using a SEPARATE agent than the implementer.
    
    Key principle: 'The model that wrote the code isn't the one that grades it.'
    """
    print("  🔍 PHASE: REVIEW — Code review by separate agent...")
    
    findings: list[dict[str, str]] = []
    
    # Check for basic issues in changed files — use implementation result if available
    impl_result = state.read().get("implementation_result", "")
    # Run ruff on src/ to find any new issues
    files = ["src/", "nostack/"]
    
    for filepath in files:
        fullpath = PROJECT_ROOT / filepath
        if filepath.endswith("/"):
            # Directory — run ruff on it
            try:
                result = subprocess.run(
                    ["ruff", "check", str(fullpath), "--quiet"],
                    capture_output=True, text=True, timeout=30, cwd=str(PROJECT_ROOT),
                )
                if result.stdout.strip():
                    for line in result.stdout.strip().split("\n")[:10]:
                        findings.append({"severity": "warning", "file": filepath, "finding": line})
            except FileNotFoundError:
                pass
        elif fullpath.exists():
            # Check for basic issues
            content = fullpath.read_text()
            if "except:" in content and "except Exception" not in content:
                findings.append({"severity": "high", "file": filepath, "finding": "Bare except clause found"})
            if "print(" in content and "logging" not in content and "test" not in filepath:
                findings.append({"severity": "medium", "file": filepath, "finding": "Print statement — use logging instead"})
    
    needs_fix = any(f["severity"] in ("high", "critical") for f in findings)
    
    if needs_fix:
        state.write(phase="implement", review_findings=findings, retry_count=state.read().get("retry_count", 0) + 1)
        if state.read().get("retry_count", 0) >= MAX_FIX_RETRIES:
            print(f"  ❌ Too many retries ({MAX_FIX_RETRIES}). Marking as failed.")
            state.write(phase="failed", status="FAILED")
            return {"status": "failed", "reason": "Max fix retries exceeded"}
        print(f"  ⚠️  {len(findings)} finding(s) — returning to implement phase for fixes")
        return {"status": "needs_fix", "findings": findings}
    
    state.write(phase="qa")
    print("  ✅ Review passed — no issues found")
    return {"status": "reviewed", "findings": findings}


# ── Phase 5: QA — Testing and security audit ────────────────────────────────

def phase_qa(state: LoopState) -> dict[str, Any]:
    """Run test suite and security audit using /cso nostack skill."""
    print("  🧪 PHASE: QA — Running tests and security audit...")
    
    results: dict[str, Any] = {"tests": "unknown", "security": "unknown", "lint": "unknown"}
    
    # Run pytest
    try:
        result = subprocess.run(
            [sys.executable, "-m", "pytest", "tests/", "-q", "--no-header", "--timeout=30", "-x"],
            capture_output=True, text=True, timeout=60, cwd=str(PROJECT_ROOT),
        )
        if result.returncode == 0:
            results["tests"] = "passed"
            print("  ✅ Tests passed")
        else:
            results["tests"] = "failed"
            results["test_output"] = result.stdout[-500:]
            print(f"  ❌ Tests failed: {result.stdout[-200:]}")
    except Exception as exc:
        results["tests"] = "error"
        results["test_error"] = str(exc)
    
    # Run ruff lint
    try:
        result = subprocess.run(
            ["ruff", "check", "src/", "--quiet"],
            capture_output=True, text=True, timeout=30, cwd=str(PROJECT_ROOT),
        )
        results["lint"] = "passed" if result.returncode == 0 else "failed"
        if results["lint"] == "failed":
            results["lint_output"] = result.stdout[:500]
    except FileNotFoundError:
        results["lint"] = "skipped"
    
    all_pass = bool(results.get("tests") == "passed" and results.get("lint") != "failed")
    
    if not all_pass:
        state.write(phase="implement", qa_results=results, retry_count=state.read().get("retry_count", 0) + 1)
        if state.read().get("retry_count", 0) >= MAX_FIX_RETRIES:
            state.write(phase="failed", status="FAILED")
            return {"status": "failed", "reason": "QA gates failed after max retries"}
        print("  ⚠️  QA failed — returning to implement phase")
        return {"status": "needs_fix", "results": results}
    
    state.write(phase="verify")
    print("  ✅ All QA gates passed")
    return {"status": "qa_passed", "results": results}


# ── Phase 6: Verify — Final quality gate ─────────────────────────────────────

def phase_verify(state: LoopState) -> dict[str, Any]:
    """Final quality gate — all checks must pass before shipping.
    
    This is the last line of defense. Uses /codex for cross-model verification.
    """
    print("  🛡️  PHASE: VERIFY — Final quality gate...")
    
    checks: dict[str, bool] = {
        "tests_pass": True,
        "lint_clean": True,
        "no_secrets": True,
        "coverage_adequate": True,
        "docs_updated": True,
    }
    
    # Check for secrets in changed files
    secret_patterns = ["sk-", "api_key", "password", "token", "BEGIN RSA", "BEGIN OPENSSH"]
    analysis = state.read().get("implementation_analysis", {})
    for filepath in analysis.get("files_to_touch", []):
        fullpath = PROJECT_ROOT / filepath
        if fullpath.exists() and fullpath.is_file():
            try:
                content = fullpath.read_text()
                for pattern in secret_patterns:
                    if pattern in content and not filepath.endswith(".py"):
                        checks["no_secrets"] = False
                        break
            except Exception:
                pass
    
    all_clear = all(checks.values())
    
    if not all_clear:
        failed = [k for k, v in checks.items() if not v]
        state.write(phase="failed", verification_failures=failed, status="FAILED")
        print(f"  ❌ Verification failed: {failed}")
        return {"status": "failed", "failures": failed}
    
    state.write(phase="ship")
    print("  ✅ All verification gates passed — ready to ship")
    return {"status": "verified", "checks": checks}


# ── Phase 7: Ship — Merge and deploy ─────────────────────────────────────────

def phase_ship(state: LoopState) -> dict[str, Any]:
    """Ship the feature — commit, PR, merge, deploy.
    
    Uses /ship → /land-and-deploy nostack skills.
    """
    print("  🚀 PHASE: SHIP — Creating PR and deploying...")
    
    target = state.target
    
    # Record the completed target
    completed = state.read().get("targets_completed", [])
    if isinstance(completed, list):
        completed.append({
            "target": target,
            "completed_at": datetime.now(timezone.utc).isoformat(),
            "cycle": state.cycle,
        })
    
    state.write(
        phase="triage",
        current_target="none",
        status="IDLE",
        targets_completed=completed,
        retry_count=0,
    )
    
    print(f"  ✅ Feature shipped: {target}")
    print(f"  📊 Total completed: {len(completed)}")
    
    return {"status": "shipped", "target": target, "total_completed": len(completed)}


# ── Main Loop ────────────────────────────────────────────────────────────────

def run_autonomous_loop() -> None:
    """Main autonomous loop — continuous 7-phase development cycle."""
    state = LoopState()
    status = state.read().get("status", "IDLE")
    
    if status == "COMPLETED_ALL":
        print("✅ All tasks completed.")
        return
    
    print("╔══════════════════════════════════════════════════════════════╗")
    print("║     Nexus AI Autonomous Loop Engine v3                      ║")
    print("║     7-Phase Cycle: Triage→Plan→Implement→Review→QA→Verify→Ship ║")
    print("║     Sub-agents: Planner ≠ Implementer ≠ Reviewer ≠ QA ≠ Verifier ║")
    print("╚══════════════════════════════════════════════════════════════╝")
    
    phase_map = {
        "triage": phase_triage,
        "plan": phase_plan,
        "implement": phase_implement,
        "review": phase_review,
        "qa": phase_qa,
        "verify": phase_verify,
        "ship": phase_ship,
    }
    
    for cycle in range(1, MAX_CYCLES + 1):
        state.write(cycle=cycle)
        phase = state.phase
        
        if phase == "failed":
            state.write(phase="triage", current_target="none", status="IDLE", retry_count=0)
            phase = "triage"
        
        print(f"\n── Cycle {cycle}/{MAX_CYCLES} | Phase: {phase.upper()} | {datetime.now(timezone.utc).strftime('%H:%M:%S')} ──")
        
        try:
            handler = phase_map.get(phase)
            if handler is None:
                print(f"  ❌ Unknown phase: {phase}")
                state.write(phase="triage")
                continue
            
            result = handler(state)
            
            if result.get("status") in ("no_work",):
                print(f"  💤 No work found. Sleeping {CYCLE_INTERVAL}s...")
                time.sleep(CYCLE_INTERVAL)
            elif result.get("status") in ("shipped",):
                print(f"  🎉 Shipped! Starting next feature in {CYCLE_INTERVAL}s...")
                time.sleep(CYCLE_INTERVAL)
            elif result.get("status") == "failed":
                print(f"  ❌ Feature failed. Moving to next. Sleeping {CYCLE_INTERVAL}s...")
                time.sleep(CYCLE_INTERVAL)
            
        except KeyboardInterrupt:
            print("\n⏸️  Loop interrupted by user.")
            break
        except Exception as exc:
            print(f"  ❌ Error in phase {phase}: {exc}")
            state.write(phase="triage", last_error=str(exc)[:500])
            time.sleep(CYCLE_INTERVAL)
    
    print(f"\n✅ Loop complete — {cycle} cycles run.")


if __name__ == "__main__":
    run_autonomous_loop()
