# ── AI Provider Keys ────────────────────────────────────────────────────────────
# Add keys for cloud providers. Nexus AI auto-falls back across all available
# providers when rate limits are hit — so even one key is enough to get started.

# Recommended (free tiers — 14,400 req/day combined across tiers)
GROQ_API_KEY=your_groq_key_here           # console.groq.com/keys
GEMINI_API_KEY=your_gemini_key_here       # aistudio.google.com/apikey

# Optional (add more for higher throughput)
CEREBRAS_API_KEY=
MISTRAL_API_KEY=                          # console.mistral.ai/api-keys
OPENROUTER_API_KEY=                       # openrouter.ai/settings/keys
COHERE_API_KEY=                           # dashboard.cohere.com/api-keys
GITHUB_MODELS_TOKEN=                      # github.com/settings/tokens (fine-grained: Models: read)
NVIDIA_API_KEY=                           # build.nvidia.com

# Paid (only if you want Claude / Grok as final fallback)
GROK_API_KEY=
CLAUDE_API_KEY=                           # console.anthropic.com/settings/keys

# ── GitHub Integration ──────────────────────────────────────────────────────────
GH_TOKEN=                                  # GitHub PAT for repo push/commit access
GITHUB_REPO=                              # Default repo URL (e.g. https://github.com/user/repo)

# ── Ollama (Local) ──────────────────────────────────────────────────────────────
# Defaults to the "ollama" service in docker-compose. No key needed.
# OLLAMA_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=glm-5.1:cloud
