# ── AI Provider Keys ────────────────────────────────────────────────────────────
# Add keys for any providers you want. Nexus AI auto-falls back across all
# configured providers — even one key is enough to get started.
#
# QUICKEST START: just set OPENROUTER_API_KEY (one key = 300+ free models)
# or GEMINI_API_KEY (instant signup at aistudio.google.com, very generous free tier)

# ── Tier 1: One key gets you everything (aggregators) ──────────────────────────
OPENROUTER_API_KEY=                       # openrouter.ai/settings/keys  — 300+ models, many free
AIMLAPI_KEY=                              # aimlapi.com                   — 200+ models, free tier

# ── Tier 2: Best free-tier direct providers ────────────────────────────────────
GEMINI_API_KEY=                           # aistudio.google.com/apikey    — Gemini + Gemma, free
GROQ_API_KEY=                             # console.groq.com/keys         — fastest inference, free
HF_TOKEN=                                 # huggingface.co/settings/tokens — thousands of models, free
GITHUB_MODELS_TOKEN=                      # github.com/settings/tokens    — fine-grained, Models: read
CF_API_TOKEN=                             # dash.cloudflare.com/profile/api-tokens
CF_ACCOUNT_ID=                            # dash.cloudflare.com (right sidebar)
SAMBANOVA_API_KEY=                        # cloud.sambanova.ai            — free, fast 70B
GLHF_API_KEY=                             # glhf.chat                     — free, HuggingFace models

# ── Tier 3: Free with signup ───────────────────────────────────────────────────
CEREBRAS_API_KEY=                         # cerebras.ai                   — ultra-fast, free tier
MISTRAL_API_KEY=                          # console.mistral.ai/api-keys   — covers mistral + codestral
TOGETHER_API_KEY=                         # api.together.xyz              — free tier, many models
FIREWORKS_API_KEY=                        # fireworks.ai                  — free tier
DEEPINFRA_API_KEY=                        # deepinfra.com                 — very cheap / free tier
HYPERBOLIC_API_KEY=                       # app.hyperbolic.xyz            — free $10 credit
NOVITA_API_KEY=                           # novita.ai                     — free tier
CHUTES_API_KEY=                           # chutes.ai                     — free, DeepSeek models
FEATHERLESS_API_KEY=                      # featherless.ai                — free tier
KLUSTER_API_KEY=                          # kluster.ai                    — free tier
NEBIUS_API_KEY=                           # studio.nebius.ai              — free credits on signup
DEEPSEEK_API_KEY=                         # platform.deepseek.com         — very cheap (~$0)
SCALEWAY_API_KEY=                         # console.scaleway.com          — free tier
LAMBDA_API_KEY=                           # lambdalabs.com                — free inference tier
MOONSHOT_API_KEY=                         # platform.moonshot.cn          — Kimi K2.5, free tier
NEETS_API_KEY=                            # neets.ai                      — free tier
INFERENCE_NET_API_KEY=                    # inference.net                 — free tier
LEPTON_API_KEY=                           # lepton.ai                     — free tier
COHERE_API_KEY=                           # dashboard.cohere.com/api-keys — free tier
NVIDIA_API_KEY=                           # build.nvidia.com              — free credits
PERPLEXITY_API_KEY=                       # perplexity.ai/settings/api    — sonar model, free tier

# ── Paid providers (optional premium fallback) ─────────────────────────────────
OPENAI_API_KEY=                           # platform.openai.com           — gpt-4o-mini cheapest
GROK_API_KEY=                             # x.ai/api                      — paid
CLAUDE_API_KEY=                           # console.anthropic.com/settings/keys — paid

# ── GitHub Integration ──────────────────────────────────────────────────────────
GH_TOKEN=                                  # GitHub PAT for repo push/commit access
GITHUB_REPO=                              # Default repo URL (e.g. https://github.com/user/repo)

# ── Ollama (Local) ──────────────────────────────────────────────────────────────
# Defaults to the "ollama" service in docker-compose. No key needed.
# OLLAMA_BASE_URL=http://ollama:11434/v1
# LLM_MODEL=glm-5.1:cloud
# ── Multi-user Auth ────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=168

# ── Startup Warmup Modes ───────────────────────────────────────────────────────
# OFF        : no startup warmup probe
# CRITICAL   : warm only key providers listed in AGENT_STARTUP_WARMUP_CRITICAL
# BACKGROUND : start server immediately, run full warmup asynchronously
# FULL       : run full warmup during startup (current legacy behavior)
AGENT_STARTUP_WARMUP_MODE=background
AGENT_STARTUP_WARMUP_CRITICAL=ollama,openrouter,gemini,groq

# ── Webhook Trigger ─────────────────────────────────────────────────────────────
# Secret for validating incoming webhook POSTs to /webhook/trigger
WEBHOOK_SECRET=

# ── MCP (Model Context Protocol) ─────────────────────────────────────────────────
# JSON array of external tool definitions, e.g.:
# MCP_TOOLS=["{"name":"github_issues","url":"https://api.github.com/repos/The-No-Hands-company/Nexus/issues?state=open"}"]
MCP_TOOLS=
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Nexus Cloud registration ──────────────────────────────────────────────────
# URL of the Nexus Cloud instance. On startup, Nexus AI registers itself as a
# tool so Cloud can route to it and issue it a subdomain.
NEXUS_CLOUD_URL=http://localhost:8787
# Must match NEXUS_CLOUD_API_KEY in Nexus-Cloud/.env
NEXUS_CLOUD_API_KEY=change-me
# Public URL of this AI node (sent to Cloud as the upstream/proxy target)
PUBLIC_URL=http://localhost:8000
